PORT=8080
NODE_ENV=development

# MongoDB Atlas → Connect → Drivers → copy connection string, replace <password>
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/lms?retryWrites=true&w=majority

# Random long string (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Cloudinary Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# After Vercel frontend deploy (e.g. https://your-app.vercel.app)
FRONTEND_URL=

# Optional: Gmail app password for password-reset emails
EMAIL_USER=
EMAIL_PASSWORD=
