# === Option A: one line (from Atlas → Connect → Drivers) ===
MONGO_URI=

# === Option B: split vars (easier on Vercel — password can have any characters) ===
# MONGODB_USER=robochamps_app
# MONGODB_PASSWORD=
# MONGODB_CLUSTER=cluster0.xxxxx.mongodb.net
# MONGODB_DB=lms

JWT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NODE_ENV=production
# Your live site URL (custom domain or Vercel URL). Do NOT set VITE_API_URL on Vercel unless API is on another host.
FRONTEND_URL=https://lms.robochamps.in
